# .env.production (FINALIZED & HARDENED)

# ============ APPLICATION ============
NODE_ENV=production
APP_VERSION=15.0.0
APP_NAME=MAGS-AI-Studio
API_PORT=3001
FRONTEND_URL=https://mags-ai.com
API_URL=https://api.mags-ai.com

# ============ SECURITY ============
JWT_SECRET=<generate-with-openssl-rand-base64-32>
JWT_EXPIRATION=604800 # 7 days
SESSION_ROTATION_INTERVAL=900000 # 15 minutes
REQUEST_SIGNATURE_SECRET=<generate-with-openssl-rand-base64-32>
ENCRYPTION_KEY=<generate-with-openssl-rand-base64-32>
ENCRYPTION_SALT=<generate-with-openssl-rand-base64-32>

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_AUTH_WINDOW_MS=300000
RATE_LIMIT_AUTH_MAX_REQUESTS=10
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX_REQUESTS=500

# ============ GEO-BLOCKING ============
GEO_BLOCKED_COUNTRIES=KP,IR,SY
GEO_ALLOWED_COUNTRIES=

# ============ DATABASE ============
DATABASE_URL=postgresql://user:password@db-production.internal:5432/mags_prod
DB_HOST=db-production.internal
DB_PORT=5432
DB_USER=db_user
DB_NAME=mags_prod
DB_POOL_MIN=10
DB_POOL_MAX=50
DB_POOL_IDLE_TIMEOUT=30000

# ============ REDIS ============
REDIS_URL=redis://redis-production.internal:6379
REDIS_HOST=redis-production.internal
REDIS_PORT=6379
REDIS_PASSWORD=<strong-redis-password>
REDIS_DB=0
REDIS_TTL=3600

# ============ BACKUP & RECOVERY ============
BACKUP_STORAGE=/backups
BACKUP_FREQUENCY=daily
BACKUP_RETENTION=30
BACKUP_ENCRYPTION_KEY=<generate-with-openssl-rand-base64-32>

# ============ COMPLIANCE & AUDIT ============
AUDIT_LOG_RETENTION=2555 # 7 years
GDPR_DATA_EXPORT_ENABLED=true
GDPR_DATA_DELETION_ENABLED=true

# ============ MONITORING & OBSERVABILITY ============
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
SENTRY_DSN=https://key@sentry.io/project
ELASTICSEARCH_URL=http://elasticsearch:9200

# ============ LOGGING ============
LOG_LEVEL=info
LOG_FORMAT=json
LOG_SERVICE=mags-backend
LOG_ENVIRONMENT=production

# ============ EMAIL & NOTIFICATIONS ============
SENDGRID_API_KEY=<sendgrid-key>
SENDGRID_FROM=noreply@mags-ai.com

# ============ STRIPE (BILLING) ============
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_PUBLIC_KEY=pk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ============ EXTERNAL SERVICES ============
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4-turbo
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ============ CDN ============
CDN_URL=https://cdn.mags-ai.com
CDN_API_KEY=<cloudflare-api-key>

# ============ DEPLOYMENT ============
ENVIRONMENT=production
REGION=us-east-1
DEPLOYMENT_ENV=production
ROLLBACK_ENABLED=true
ZERO_DOWNTIME_DEPLOYMENT=true

# ============ PERFORMANCE ============
COMPRESSION_LEVEL=9
CACHE_STRATEGY=aggressive
QUERY_TIMEOUT=5000
MAX_REQUEST_SIZE=10mb
