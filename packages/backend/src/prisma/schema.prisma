generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// PHASES 1-5: Previous models (User, Agent, Task, Chat, etc.)
// ============================================================================
// (All existing models from Phases 1-5 remain unchanged)

model User {
  id            String        @id @default(cuid())
  email         String        @unique @db.VarChar(255)
  username      String        @unique @db.VarChar(50)
  password      String        @db.Text
  firstName     String?       @db.VarChar(100)
  lastName      String?       @db.VarChar(100)
  avatar        String?       @db.Text
  bio           String?       @db.Text
  phone         String?       @db.VarChar(20)
  emailVerified Boolean       @default(false)
  isActive      Boolean       @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations - Phases 3-5
  userRoles      UserRole[]    @relation("UserRoles")
  sessions       Session[]     @relation("UserSessions")
  refreshTokens  RefreshToken[] @relation("UserRefreshTokens")
  auditLogs      AuditLog[]    @relation("UserAuditLogs")
  passwordResets PasswordReset[] @relation("UserPasswordResets")
  chats          Chat[]        @relation("UserChats")
  chatMessages   ChatMessage[] @relation("UserChatMessages")
  agents         Agent[]       @relation("UserAgents")
  tasks          AgentTask[]   @relation("UserTasks")
  workflows      AgentWorkflow[] @relation("UserWorkflows")
  agentMemories  AgentMemory[] @relation("UserMemories")

  // Relations - Phase 6
  repositories   Repository[]  @relation("UserRepositories")
  repoFiles      RepoFile[]    @relation("UserRepoFiles")
  analysisLogs   AnalysisLog[] @relation("UserAnalysisLogs")

  @@index([email])
  @@index([username])
  @@map("users")
}

// (Previous models from Phases 3-5: Role, Permission, Chat, Agent, etc.)

// ============================================================================
// PHASE 6: Repository Intelligence System (NEW)
// ============================================================================

model Repository {
  id            String   @id @default(cuid())
  userId        String
  
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  url           String?  @db.VarChar(500) // GitHub URL or null for uploaded
  
  // Source information
  source        String   @db.VarChar(50) // "github", "local"
  owner         String?  @db.VarChar(255) // GitHub owner
  language      String?  @db.VarChar(50) // Primary language
  
  // Indexing status
  indexStatus   String   @db.VarChar(50) @default("pending") // pending, indexing, indexed, failed
  indexProgress Int      @default(0) // Percentage
  lastIndexedAt DateTime?
  
  // Statistics
  totalFiles    Int      @default(0)
  totalLines    Int      @default(0)
  totalChunks   Int      @default(0)
  
  // Metadata
  isPublic      Boolean  @default(false)
  isArchived    Boolean  @default(false)
  commitHash    String?  @db.VarChar(40) // Latest commit indexed
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user          User     @relation("UserRepositories", fields: [userId], references: [id], onDelete: Cascade)
  files         RepoFile[] @relation("RepoFiles")
  chunks        CodeChunk[] @relation("RepoChunks")
  embeddings    CodeEmbedding[] @relation("RepoEmbeddings")
  graphNodes    RepoGraphNode[] @relation("RepoGraphNodes")
  graphEdges    RepoGraphEdge[] @relation("RepoGraphEdges")
  indexJobs     IndexJob[] @relation("RepoIndexJobs")
  analyses      AnalysisLog[] @relation("RepoAnalysisLogs")

  @@index([userId])
  @@index([indexStatus])
  @@index([language])
  @@index([createdAt])
  @@map("repositories")
}

model RepoFile {
  id            String   @id @default(cuid())
  userId        String
  repoId        String
  
  path          String   @db.VarChar(500) // Relative path from repo root
  name          String   @db.VarChar(255) // File name
  language      String?  @db.VarChar(50) // JavaScript, Python, etc.
  
  // Content metadata
  size          Int      // File size in bytes
  lineCount     Int      @default(0)
  
  // Content (store for viewer)
  content       String?  @db.Text // Actual file content (may be null if too large)
  contentHash   String?  @db.VarChar(64) // SHA256 for change detection
  
  // Structure
  functions     Json?    // Array of function/method definitions
  classes       Json?    // Array of class definitions
  imports       String[] @default([]) // Imported modules
  exports       String[] @default([]) // Exported symbols
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user          User     @relation("UserRepoFiles", fields: [userId], references: [id], onDelete: Cascade)
  repository    Repository @relation("RepoFiles", fields: [repoId], references: [id], onDelete: Cascade)
  chunks        CodeChunk[] @relation("FileChunks")

  @@unique([repoId, path])
  @@index([userId])
  @@index([repoId])
  @@index([language])
  @@map("repo_files")
}

model CodeChunk {
  id            String   @id @default(cuid())
  repoId        String
  fileId        String
  
  // Content
  content       String   @db.Text
  startLine     Int
  endLine       Int
  
  // Type of chunk
  chunkType     String   @db.VarChar(50) // "function", "class", "import", "generic"
  name          String?  @db.VarChar(255) // Function/class name
  
  // Context
  language      String?  @db.VarChar(50)
  metadata      Json?    // Additional metadata (parameters, returns, etc.)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  repository    Repository @relation("RepoChunks", fields: [repoId], references: [id], onDelete: Cascade)
  file          RepoFile @relation("FileChunks", fields: [fileId], references: [id], onDelete: Cascade)
  embeddings    CodeEmbedding[] @relation("ChunkEmbeddings")

  @@index([repoId])
  @@index([fileId])
  @@index([chunkType])
  @@map("code_chunks")
}

model CodeEmbedding {
  id            String   @id @default(cuid())
  repoId        String
  chunkId       String
  
  // Vector embedding
  embedding     Vector(1536) // OpenAI embeddings are 1536 dimensions
  
  // Metadata
  modelUsed     String   @db.VarChar(100) // Model that generated this embedding
  
  createdAt     DateTime @default(now())

  // Relations
  repository    Repository @relation("RepoEmbeddings", fields: [repoId], references: [id], onDelete: Cascade)
  chunk         CodeChunk @relation("ChunkEmbeddings", fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([repoId])
  @@index([chunkId])
  @@map("code_embeddings")
}

model RepoGraphNode {
  id            String   @id @default(cuid())
  repoId        String
  
  // Node info
  nodeId        String   @db.VarChar(255) // Unique identifier within repo (file path, function name, etc.)
  nodeType      String   @db.VarChar(50) // "file", "function", "class", "module"
  label         String   @db.VarChar(255)
  
  // Reference
  fileId        String?
  
  // Metadata
  metadata      Json?
  
  createdAt     DateTime @default(now())

  // Relations
  repository    Repository @relation("RepoGraphNodes", fields: [repoId], references: [id], onDelete: Cascade)
  file          RepoFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)
  incomingEdges RepoGraphEdge[] @relation("EdgeTarget")
  outgoingEdges RepoGraphEdge[] @relation("EdgeSource")

  @@unique([repoId, nodeId])
  @@index([repoId])
  @@index([nodeType])
  @@map("repo_graph_nodes")
}

model RepoGraphEdge {
  id            String   @id @default(cuid())
  repoId        String
  
  sourceNodeId  String
  targetNodeId  String
  
  // Edge type
  edgeType      String   @db.VarChar(50) // "imports", "calls", "inherits", "references"
  
  // Metadata
  metadata      Json?
  
  createdAt     DateTime @default(now())

  // Relations
  repository    Repository @relation("RepoGraphEdges", fields: [repoId], references: [id], onDelete: Cascade)
  sourceNode    RepoGraphNode @relation("EdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode    RepoGraphNode @relation("EdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([repoId, sourceNodeId, targetNodeId, edgeType])
  @@index([repoId])
  @@index([edgeType])
  @@map("repo_graph_edges")
}

model IndexJob {
  id            String   @id @default(cuid())
  repoId        String
  
  jobType       String   @db.VarChar(50) // "initial_index", "re_index", "chunk_update"
  status        String   @db.VarChar(50) @default("pending") // pending, running, completed, failed
  
  // Progress tracking
  filesProcessed Int     @default(0)
  totalFiles    Int
  chunksGenerated Int    @default(0)
  embeddingsGenerated Int @default(0)
  
  // Execution info
  startedAt     DateTime?
  completedAt   DateTime?
  errorMessage  String?  @db.Text
  
  createdAt     DateTime @default(now())

  // Relations
  repository    Repository @relation("RepoIndexJobs", fields: [repoId], references: [id], onDelete: Cascade)

  @@index([repoId])
  @@index([status])
  @@map("index_jobs")
}

model AnalysisLog {
  id            String   @id @default(cuid())
  userId        String
  repoId        String
  
  analysisType  String   @db.VarChar(50) // "explain", "summarize", "bug_detect", "impact", "improve"
  query         String   @db.Text
  
  // Results
  result        Json?    // Analysis result/response
  confidence    Float?   // Confidence score (0-1)
  relevantChunks String[] @default([]) // IDs of code chunks used
  
  // Performance
  processingTimeMs Int?
  
  createdAt     DateTime @default(now())

  // Relations
  user          User     @relation("UserAnalysisLogs", fields: [userId], references: [id], onDelete: Cascade)
  repository    Repository @relation("RepoAnalysisLogs", fields: [repoId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([repoId])
  @@index([analysisType])
  @@map("analysis_logs")
}
