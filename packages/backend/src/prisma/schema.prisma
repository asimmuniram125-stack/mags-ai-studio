generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "metrics"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USERS & AUTHENTICATION ============
model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  emailVerified         DateTime?
  password              String    // Encrypted
  firstName             String?
  lastName              String?
  avatar                String?
  status                String    @default("active") // active, suspended, banned
  mfaEnabled            Boolean   @default(false)
  mfaSecret             String?   @db.VarChar(255)
  lastLogin             DateTime?
  lastLoginIP           String?
  lastLoginUserAgent    String?
  loginAttempts         Int       @default(0)
  lockoutUntil          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime? // Soft delete for GDPR
  
  // Relations
  profile               UserProfile?
  settings              UserSettings?
  sessions              Session[]
  auditLogs             AuditLog[]
  subscriptions         Subscription[]
  organizations         Organization[]
  devices               Device[]
  
  // Indexes
  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([lastLogin])
  @@fulltext([email, firstName, lastName]) // Full-text search
}

model UserProfile {
  id                String  @id @default(cuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio               String?
  company           String?
  location          String?
  website           String?
  timezone          String?
  language          String  @default("en")
  twoFactorEnabled  Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

model UserSettings {
  id                String  @id @default(cuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications Boolean @default(true)
  smsNotifications  Boolean @default(false)
  pushNotifications Boolean @default(true)
  theme             String  @default("light")
  dataExportFormat  String  @default("json")
  privacyLevel      String  @default("private") // private, friends, public
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

model Session {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  token             String  @unique // Hashed
  deviceFingerprint String?
  ipAddress         String
  userAgent         String
  expiresAt         DateTime
  revokedAt         DateTime?
  rotationRequired  Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([ipAddress])
}

model Device {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  type              String  // mobile, desktop, tablet
  fingerprint       String  @unique
  lastSeenAt        DateTime
  trustedAt         DateTime?
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([fingerprint])
}

// ============ ORGANIZATIONS & TEAMS ============
model Organization {
  id                String  @id @default(cuid())
  ownerId           String
  owner             User    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  name              String
  slug              String  @unique
  description       String?
  logo              String?
  status            String  @default("active")
  tier              String  @default("free") // free, pro, enterprise
  members           OrganizationMember[]
  subscriptions     Subscription[]
  apiKeys           ApiKey[]
  auditLogs         AuditLog[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([ownerId])
  @@index([slug])
}

model OrganizationMember {
  id              String  @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String
  role            String  @default("member") // owner, admin, member
  joinedAt        DateTime @default(now())
  permissions     Json    @default("{}")
  
  @@unique([organizationId, userId])
  @@index([organizationId])
}

// ============ SUBSCRIPTIONS & BILLING ============
model Subscription {
  id                String  @id @default(cuid())
  userId            String?
  user              User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan              String  // free, pro, enterprise
  status            String  @default("active") // active, canceled, paused
  currentPeriodStart DateTime
  currentPeriodEnd  DateTime
  canceledAt        DateTime?
  stripeSubscriptionId String? @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([status])
}

model Invoice {
  id                String  @id @default(cuid())
  organizationId    String
  organization      Organization @relation("Invoices", fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionId    String?
  amount            BigInt  // In cents
  currency          String  @default("USD")
  status            String  @default("pending") // pending, paid, failed
  paidAt            DateTime?
  dueAt             DateTime
  stripeInvoiceId   String? @unique
  pdf               String? // URL to PDF
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
}

// ============ API KEYS & WEBHOOKS ============
model ApiKey {
  id                String  @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  key               String  @unique @db.VarChar(255)
  secret            String  @db.VarChar(255)
  lastUsedAt        DateTime?
  expiresAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([key])
}

model Webhook {
  id                String  @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  url               String
  events            String[] // Events to listen for
  secret            String
  active            Boolean @default(true)
  lastTriggeredAt   DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([active])
}

// ============ AUDIT & COMPLIANCE ============
model AuditLog {
  id                String  @id @default(cuid())
  userId            String?
  user              User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  action            String
  resourceType      String
  resourceId        String
  changes           Json    @default("{}")
  ipAddress         String
  userAgent         String
  checksum          String  @db.VarChar(255) // For immutability verification
  status            String  @default("success")
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
}

model DataRetention {
  id                String  @id @default(cuid())
  organizationId    String  @unique
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  retentionDays     Int     @default(90)
  autoDelete        Boolean @default(true)
  lastRunAt         DateTime?
  nextRunAt         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
}

// ============ ANALYTICS & MONITORING ============
model AnalyticsEvent {
  id                String  @id @default(cuid())
  organizationId    String?
  userId            String?
  event             String
  properties        Json    @default("{}")
  timestamp         DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([event])
  @@index([timestamp])
}

model SystemLog {
  id                String  @id @default(cuid())
  level             String  // info, warning, error, critical
  service           String
  message           String
  context           Json    @default("{}")
  timestamp         DateTime @default(now())

  @@index([level])
  @@index([service])
  @@index([timestamp])
}

model HealthCheckLog {
  id                String  @id @default(cuid())
  component         String
  status            String  // healthy, degraded, unhealthy
  responseTime      Int     // ms
  errors            String?
  timestamp         DateTime @default(now())

  @@index([component])
  @@index([status])
  @@index([timestamp])
}

// ============ BACKUPS & DISASTER RECOVERY ============
model Backup {
  id                String  @id @default(cuid())
  backupId          String  @unique
  size              BigInt
  type              String  // full, incremental
  status            String  @default("completed")
  location          String
  checksum          String
  restoredAt        DateTime?
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
}

model Deployment {
  id                String  @id @default(cuid())
  version           String
  commit            String
  status            String  // pending, in-progress, successful, failed, rolled-back
  environment       String  // development, staging, production
  deployedBy        String?
  startedAt         DateTime
  completedAt       DateTime?
  rolledBackAt      DateTime?
  logs              String?
  createdAt         DateTime @default(now())

  @@index([status])
  @@index([environment])
  @@index([version])
}
