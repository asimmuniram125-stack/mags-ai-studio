# .env.production.final (COMPLETE PHASE 16)

# ============ APPLICATION ============
NODE_ENV=production
APP_VERSION=16.0.0
APP_NAME=MAGS-AI-Studio
API_PORT=3001
FRONTEND_URL=https://mags-ai.com
API_URL=https://api.mags-ai.com

# ============ LAUNCH CONFIGURATION ============
RELEASE_ENABLED=true
FEATURE_FLAGS_ENABLED=true
ONBOARDING_ENABLED=true
GRADUAL_ROLLOUT_ENABLED=true
BETA_TESTING_ENABLED=true
DOCUMENTATION_ENABLED=true
FEEDBACK_ENABLED=true
ADOPTION_TRACKING_ENABLED=true

# ============ FEATURE FLAG SETTINGS ============
FEATURE_FLAG_CACHE_TTL=300
DEFAULT_ROLLOUT_PERCENTAGE=0
BETA_TESTERS_GROUP=beta-testers

# ============ ONBOARDING SETTINGS ============
ONBOARDING_REQUIRED=true
ONBOARDING_TIMEOUT_DAYS=30
SHOW_PRODUCT_TOUR=true
AUTO_SKIP_ON_TIMEOUT=false

# ============ RELEASE MANAGEMENT ============
AUTO_ROLLBACK_ENABLED=true
ROLLBACK_ERROR_THRESHOLD=5
HEALTH_CHECK_INTERVAL=30000
RELEASE_NOTIFICATION_ENABLED=true

# ============ SECURITY ============
JWT_SECRET=generate-with-openssl-rand-base64-32
JWT_EXPIRATION=604800
REQUEST_SIGNATURE_SECRET=generate-with-openssl-rand-base64-32
ENCRYPTION_KEY=generate-with-openssl-rand-base64-32
ENCRYPTION_SALT=generate-with-openssl-rand-base64-32

# ============ DATABASE ============
DATABASE_URL=postgresql://user:password@db-production.internal:5432/mags_prod
DB_HOST=db-production.internal
DB_PORT=5432
DB_USER=db_user
DB_NAME=mags_prod

# ============ REDIS ============
REDIS_URL=redis://redis-production.internal:6379
REDIS_HOST=redis-production.internal
REDIS_PORT=6379
REDIS_PASSWORD=strong-redis-password

# ============ MONITORING & OBSERVABILITY ============
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
SENTRY_DSN=https://key@sentry.io/project
ELASTICSEARCH_URL=http://elasticsearch:9200

# ============ LOGGING ============
LOG_LEVEL=info
LOG_FORMAT=json
LOG_SERVICE=mags-backend

# ============ BILLING & ANALYTICS ============
STRIPE_SECRET_KEY=sk_live_xxxxx
ANALYTICS_TRACKING_ENABLED=true
ADOPTION_TRACKING_ENABLED=true
NPS_SURVEY_ENABLED=true

# ============ EXTERNAL SERVICES ============
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4-turbo
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ============ CDN & STORAGE ============
CDN_URL=https://cdn.mags-ai.com
AWS_REGION=us-east-1
S3_BUCKET=mags-production-bucket

# ============ DEPLOYMENT & RELEASE ============
ENVIRONMENT=production
REGION=us-east-1
ZERO_DOWNTIME_DEPLOYMENT=true
DEPLOYMENT_ENV=production
