generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// PHASE 1: User & Authentication Models
// ============================================================================

model User {
  id            String        @id @default(cuid())
  email         String        @unique @db.VarChar(255)
  username      String        @unique @db.VarChar(50)
  password      String        @db.Text
  firstName     String?       @db.VarChar(100)
  lastName      String?       @db.VarChar(100)
  avatar        String?       @db.Text
  bio           String?       @db.Text
  phone         String?       @db.VarChar(20)
  emailVerified Boolean       @default(false)
  isActive      Boolean       @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  userRoles      UserRole[]    @relation("UserRoles")
  sessions       Session[]     @relation("UserSessions")
  refreshTokens  RefreshToken[] @relation("UserRefreshTokens")
  auditLogs      AuditLog[]    @relation("UserAuditLogs")
  passwordResets PasswordReset[] @relation("UserPasswordResets")
  chats          Chat[]        @relation("UserChats")
  chatMessages   ChatMessage[] @relation("UserChatMessages")
  agents         Agent[]       @relation("UserAgents")
  tasks          AgentTask[]   @relation("UserTasks")
  workflows      AgentWorkflow[] @relation("UserWorkflows")
  agentMemories  AgentMemory[] @relation("UserMemories")

  @@index([email])
  @@index([username])
  @@index([isActive])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles   UserRole[] @relation("RoleUsers")
  permissions RolePermission[] @relation("RolePermissions")

  @@index([name])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  category    String   @db.VarChar(50) @default("general")
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[] @relation("PermissionRoles")

  @@index([name])
  @@index([category])
  @@map("permissions")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  assignedAt DateTime @default(now())

  user      User     @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation("RoleUsers", fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id        String   @id @default(cuid())
  roleId    String
  permissionId String
  assignedAt DateTime @default(now())

  role       Role       @relation("RolePermissions", fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation("PermissionRoles", fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@map("role_permissions")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique @db.Text
  ipAddress    String?  @db.VarChar(45)
  userAgent    String?  @db.Text
  isActive     Boolean  @default(true)
  lastActivityAt DateTime @default(now())
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  user         User     @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation("UserRefreshTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @db.Text
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation("UserPasswordResets", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   @db.VarChar(255)
  resource  String   @db.VarChar(100)
  details   Json?
  ipAddress String?  @db.VarChar(45)
  createdAt DateTime @default(now())

  user      User     @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// PHASE 4: Chat System Models
// ============================================================================

model Chat {
  id          String   @id @default(cuid())
  userId      String
  title       String   @db.VarChar(255) @default("New Chat")
  description String?  @db.Text
  modelId     String   @default("gpt-4")
  systemPrompt String? @db.Text
  temperature Float   @default(0.7)
  maxTokens   Int     @default(4000)
  topP        Float   @default(1.0)
  messageCount Int    @default(0)
  tokenUsage  Int     @default(0)
  isActive    Boolean @default(true)
  isPinned    Boolean @default(false)
  isFavorite  Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastMessageAt DateTime?
  archivedAt  DateTime?

  user         User          @relation("UserChats", fields: [userId], references: [id], onDelete: Cascade)
  messages     ChatMessage[] @relation("ChatMessages")
  sessions     ChatSession[] @relation("ChatSessions")
  agentAccess  AgentChatAccess[] @relation("ChatAgentAccess")

  @@index([userId])
  @@index([isActive])
  @@index([createdAt])
  @@map("chats")
}

model ChatMessage {
  id         String   @id @default(cuid())
  chatId     String
  userId     String
  role       String   @db.VarChar(20)
  content    String   @db.Text
  tokens     Int?
  modelUsed  String?  @db.VarChar(100)
  isStreaming Boolean @default(false)
  isEdited   Boolean  @default(false)
  editedAt   DateTime?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  chat       Chat     @relation("ChatMessages", fields: [chatId], references: [id], onDelete: Cascade)
  user       User     @relation("UserChatMessages", fields: [userId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([userId])
  @@map("chat_messages")
}

model ChatSession {
  id           String   @id @default(cuid())
  chatId       String
  sessionToken String   @unique @db.Text
  ipAddress    String?  @db.VarChar(45)
  userAgent    String?  @db.Text
  isActive     Boolean  @default(true)
  lastActivityAt DateTime @default(now())
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  chat         Chat     @relation("ChatSessions", fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([sessionToken])
  @@map("chat_sessions")
}

model AIModelConfig {
  id           String   @id @default(cuid())
  name         String   @unique @db.VarChar(100)
  provider     String   @db.VarChar(50)
  apiModel     String   @db.VarChar(100)
  maxTokens    Int      @default(8000)
  costPerToken Float   @default(0.0)
  isActive     Boolean  @default(true)
  defaultTemperature Float @default(0.7)
  defaultTopP Float @default(1.0)
  version      String   @db.VarChar(50)
  releaseDate  DateTime?
  deprecatedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([provider])
  @@index([isActive])
  @@map("ai_model_configs")
}

// ============================================================================
// PHASE 5: Agent System Models
// ============================================================================

model Agent {
  id           String   @id @default(cuid())
  userId       String
  name         String   @db.VarChar(255)
  description  String?  @db.Text
  type         String   @db.VarChar(50)
  
  modelId      String   @default("gpt-4")
  systemPrompt String   @db.Text
  temperature  Float    @default(0.7)
  maxTokens    Int      @default(4000)
  topP         Float    @default(1.0)
  
  tools        String[] @default([])
  permissions  String[] @default([])
  
  isActive     Boolean  @default(true)
  isPublic     Boolean  @default(false)
  
  taskCount    Int      @default(0)
  totalTokens  Int      @default(0)
  successRate  Float    @default(0.0)
  
  avatar       String?  @db.Text
  color        String?  @db.VarChar(7)
  tags         String[] @default([])
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User           @relation("UserAgents", fields: [userId], references: [id], onDelete: Cascade)
  tasks        AgentTask[]    @relation("AgentTasks")
  memories     AgentMemory[]  @relation("AgentMemories")
  workflows    AgentWorkflow[] @relation("WorkflowAgents")
  logs         AgentExecutionLog[] @relation("AgentLogs")
  chatAccess   AgentChatAccess[] @relation("AgentChatAccess")

  @@index([userId])
  @@index([type])
  @@index([isActive])
  @@index([createdAt])
  @@map("agents")
}

model AgentTask {
  id           String   @id @default(cuid())
  userId       String
  agentId      String?
  
  title        String   @db.VarChar(255)
  description  String?  @db.Text
  goal         String   @db.Text
  
  input        Json?
  context      String?  @db.Text
  
  status       String   @db.VarChar(50) @default("pending")
  priority     String   @db.VarChar(20) @default("medium")
  
  startedAt    DateTime?
  completedAt  DateTime?
  durationMs   Int?
  
  result       Json?
  error        String?  @db.Text
  
  subtasks     String[] @default([])
  parentTaskId String?
  
  metadata     Json?
  retryCount   Int      @default(0)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation("UserTasks", fields: [userId], references: [id], onDelete: Cascade)
  agent        Agent?   @relation("AgentTasks", fields: [agentId], references: [id], onDelete: SetNull)
  parentTask   AgentTask? @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  childTasks   AgentTask[] @relation("TaskSubtasks")
  logs         AgentExecutionLog[] @relation("TaskLogs")

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("agent_tasks")
}

model AgentMemory {
  id           String   @id @default(cuid())
  userId       String
  agentId      String
  
  type         String   @db.VarChar(50)
  
  content      String   @db.Text
  embedding    String?  @db.Text
  
  relevance    Float    @default(1.0)
  accessCount  Int      @default(0)
  lastAccessedAt DateTime?
  expiresAt    DateTime?
  
  linkedTaskId String?
  linkedChatId String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation("UserMemories", fields: [userId], references: [id], onDelete: Cascade)
  agent        Agent    @relation("AgentMemories", fields: [agentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agentId])
  @@index([type])
  @@index([relevance])
  @@index([createdAt])
  @@map("agent_memories")
}

model AgentWorkflow {
  id           String   @id @default(cuid())
  userId       String
  
  name         String   @db.VarChar(255)
  description  String?  @db.Text
  
  nodes        Json
  edges        Json
  config       Json?
  
  isActive     Boolean  @default(true)
  isDraft      Boolean  @default(true)
  
  executionCount Int    @default(0)
  lastExecutedAt DateTime?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation("UserWorkflows", fields: [userId], references: [id], onDelete: Cascade)
  agents       Agent[]  @relation("WorkflowAgents")
  executions   AgentWorkflowExecution[] @relation("WorkflowExecutions")

  @@index([userId])
  @@index([isActive])
  @@index([createdAt])
  @@map("agent_workflows")
}

model AgentWorkflowExecution {
  id           String   @id @default(cuid())
  workflowId   String
  
  status       String   @db.VarChar(50) @default("running")
  
  result       Json?
  error        String?  @db.Text
  
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  durationMs   Int?
  
  createdAt    DateTime @default(now())

  workflow     AgentWorkflow @relation("WorkflowExecutions", fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([status])
  @@map("agent_workflow_executions")
}

model AgentExecutionLog {
  id           String   @id @default(cuid())
  agentId      String
  taskId       String?
  
  level        String   @db.VarChar(20)
  message      String   @db.Text
  
  reasoning    String?  @db.Text
  toolsUsed    String[] @default([])
  
  input        Json?
  output       Json?
  
  createdAt    DateTime @default(now())

  agent        Agent    @relation("AgentLogs", fields: [agentId], references: [id], onDelete: Cascade)
  task         AgentTask? @relation("TaskLogs", fields: [taskId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([taskId])
  @@index([level])
  @@index([createdAt])
  @@map("agent_execution_logs")
}

model AgentChatAccess {
  id           String   @id @default(cuid())
  agentId      String
  chatId       String
  
  accessedAt   DateTime @default(now())
  lastUsedAt   DateTime?
  
  canRead      Boolean  @default(true)
  canWrite     Boolean  @default(true)
  canExecute   Boolean  @default(true)

  agent        Agent    @relation("AgentChatAccess", fields: [agentId], references: [id], onDelete: Cascade)
  chat         Chat     @relation("ChatAgentAccess", fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([agentId, chatId])
  @@index([agentId])
  @@index([chatId])
  @@map("agent_chat_access")
}
